//ejercicio2 GET/categorias
app.get("/categorias", async (req, res) => {
  try {
    const [categorias] = await conexion.query("SELECT * FROM categorias");
    res.json(categorias);
  } catch (error) {
    res.status(500).json({
      mensaje: "Error al obtener las categorías",
      error: error.message
    });
  }
});
